# Neon Postgres — https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Auth session signing secret (min 16 characters)
AUTH_SECRET=your-long-random-secret-string-here

# ElevenLabs — REQUIRED for TTS, speech-to-text, and agent sessions
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Optional: Conversational AI agent (works WITH api key, not instead of it)
# https://elevenlabs.io/app/agents → copy Agent ID
ELEVENLABS_AGENT_ID=your-agent-id

# Default voice ID for Speak buttons (Voice Library → copy Voice ID)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional alternate voices for Settings → Voice type
ELEVENLABS_VOICE_ID_CALM=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_FRIENDLY=EXAVITQu4vr4xnSDxMaL
